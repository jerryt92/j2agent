COMPOSE_PROJECT_NAME=j2agent
TAG=1.0.0
I18N=zh_CN
JWT_SECRET="base64:iiWkZ2kCYEdglYrQi/SofZybjnptG7bId5gnl4dUBNI="
J2AGENT_VOLUMES_PATH=.
DIR_PATH_SEPARATOR=/
J2AGENT_PORT=30111
J2AGENT_HTTPS_ENABLED=false
J2AGENT_HTTP_REDIRECT_PORT=
J2AGENT_HTTPS_CERT_FILE=j2agent.crt
J2AGENT_HTTPS_KEY_FILE=j2agent.key
JAVA_OPTS="-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:MetaspaceSize=128m -XX:MaxMetaspaceSize=256m -XX:+HeapDumpOnOutOfMemoryError -Dfile.encoding=utf-8 -XX:HeapDumpPath=/opt/j2agent/volume/logs/j2agent.hprof"
SPRING_OPTIONS="--spring.profiles.active=product"

# ============================================================
# 中间件部署配置（docker-compose 使用）
# ============================================================
POSTGRES_PORT=35432
POSTGRES_DB=j2agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=j2apassword@2026#
REDIS_PORT=36379
REDIS_PASSWORD=
MILVUS_PORT=19530
MILVUS_HEALTH_PORT=9091
# RustFS 默认容器端口为 9000/9001；宿主机默认端口在前面加 1，避免占用原生端口
RUSTFS_API_PORT=19000
RUSTFS_CONSOLE_PORT=19001
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=j2apassword@2026#
MILVUS_TOKEN=root:Milvus

# ============================================================
# 中间件连接配置（应用运行时使用）
# ============================================================
J2AGENT_DB_HOST=postgres
J2AGENT_DB_PORT=5432
J2AGENT_DB_USERNAME=${POSTGRES_USER}
J2AGENT_DB_PASSWORD=${POSTGRES_PASSWORD}
J2AGENT_REDIS_HOST=redis
J2AGENT_REDIS_PORT=6379
J2AGENT_REDIS_PASSWORD=${REDIS_PASSWORD}
J2AGENT_MILVUS_HOST=milvus
J2AGENT_MILVUS_PORT=${MILVUS_PORT}
J2AGENT_MILVUS_TOKEN=${MILVUS_TOKEN}
J2AGENT_MILVUS_SCHEMA_CONFIG_PATH=
# 对象存储（type 可选 s3、aliyun-oss（阿里云 OSS）或 qiniu（七牛云））
J2AGENT_STORAGE_ENABLED=true
J2AGENT_STORAGE_TYPE=s3
J2AGENT_STORAGE_BUCKET=j2agent-files
# 对象存储访问方式：proxy（默认，同源代理）| direct（OSS 预签名直链）
J2AGENT_STORAGE_ACCESS_MODE=proxy
# S3 兼容存储（type=s3）；默认须与 RustFS 容器 RUSTFS_* 保持一致
J2AGENT_S3_ENDPOINT=http://rustfs:9000
J2AGENT_S3_ACCESS_KEY_ID=rustfsadmin
J2AGENT_S3_SECRET_ACCESS_KEY=j2apassword@2026#
J2AGENT_STORAGE_SYNC_RETENTION_DAYS=7
J2AGENT_STORAGE_SYNC_CLEANUP_CRON=0 30 2 * * *
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_DOMAIN=
QINIU_USE_HTTPS=true
